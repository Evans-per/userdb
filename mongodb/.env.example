# MongoDB Connection String (Required for database operations)
# Get this from MongoDB Atlas → Connect → Connection String
MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/databaseName?ssl=true&replicaSet=atlas-prd-0&authSource=admin&retryWrites=true&w=majority

# Server Port (Vercel sets this automatically)
PORT=5000

# Environment
NODE_ENV=development
